    {
      "parameters": {
        "jsCode": "const newItems = [];\n\nfor (const item of $input.all()) {\n  const paths = item.json.path;\n\n  // 0. Validação de Esquema\n  if (!Array.isArray(paths)) {\n    throw new Error(`Formato inválido. O campo 'path' deve ser um array de strings.`);\n  }\n\n  for (let p of paths) {\n    if (typeof p !== 'string') {\n      throw new Error(`Acesso negado: Um dos caminhos fornecidos não é um texto válido.`);\n    }\n\n    // --- LÓGICA DE RAIZ VIRTUAL ---\n    // Garante que todo caminho comece com \"/\" e remove barras duplas\n    if (!p.startsWith('/')) {\n      p = '/' + p;\n    }\n    p = p.replace(/\\/+/g, '/');\n\n    // 1. Bloqueia \"..\" (Path Traversal)\n    if (p.includes(\"..\")) {\n      throw new Error(`Acesso negado: Tentativa de Path Traversal (..) ao tentar listar ${p}`);\n    }\n\n    // 2. Bloqueia diretórios sensíveis ou muito pesados\n    const restrictedPattern = /(^|\\/)\\.?(env|git|node_modules|__pycache__|venv)(\\.|$|\\/)/i;\n    if (restrictedPattern.test(p)) {\n      throw new Error(`Acesso negado: Tentativa de listar diretório restrito ou excessivamente grande: ${p}`);\n    }\n\n    // 3. Validação rigorosa de caracteres\n    const safePattern = /^[a-zA-Z0-9/ \\-_\\.]+$/;\n    if (!safePattern.test(p)) {\n      throw new Error(`Acesso negado: O caminho contém caracteres perigosos ou não permitidos: ${p}`);\n    }\n\n    // 4. Validação de prefixos permitidos\n    const allowedDirs = [\"/apps/\", \"/docs/\", \"/config/\"];\n    \n    // Arquivos específicos permitidos (sem a raiz \"/\")\n    const allowedExactPaths = [\"/README.md\", \"/AGENTS.md\"]; \n\n    const hasAllowedPrefix = allowedDirs.some(prefix => p.startsWith(prefix));\n    const isAllowedExactPath = allowedExactPaths.includes(p);\n\n    if (!hasAllowedPrefix && !isAllowedExactPath) {\n      throw new Error(`Acesso negado: O diretório '${p}' não está na lista de locais permitidos para listagem.`);\n    }\n\n    // --- PREPARAÇÃO DO OUTPUT ---\n    const cleanJson = { ...item.json };\n    delete cleanJson.path; \n    \n    // Passa o caminho normalizado para o próximo nó\n    cleanJson.safePath = p;\n\n    newItems.push({\n      json: cleanJson\n    });\n  }\n}\n\nreturn newItems;"
      },
