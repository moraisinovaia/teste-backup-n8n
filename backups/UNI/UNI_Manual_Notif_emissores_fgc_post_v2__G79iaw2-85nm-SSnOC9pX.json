    {
      "parameters": {
        "language": "python",
        "pythonCode": "# Code in Python (Beta) — Run Once for All Items\n# Gera 1 saída por responsável, com descrição em HTML e pairedItem preservado.\n\nfrom html import escape\n\ndef to_brl(n: float) -> str:\n    \"\"\"Formata número como 1.234.567,89.\"\"\"\n    return f\"{n:,.2f}\".replace(\",\", \"X\").replace(\".\", \",\").replace(\"X\", \".\")\n\ndef ensure_list(name, value):\n    if isinstance(value, list):\n        return value\n    try:\n        return value.to_py()\n    except Exception as e:\n        raise TypeError(f\"{name} não é lista nem JsProxy convertível: {type(value)}\") from e\n\ndef ensure_dict(name, value):\n    if isinstance(value, dict):\n        return value\n    try:\n        return value.to_py()\n    except Exception as e:\n        raise TypeError(f\"{name} não é dict nem JsProxy convertível: {type(value)}\") from e\n\nnew_items = []\n\nfor idx, item in enumerate(_input.all()):\n    j = item.json.to_py()\n\n    nome = j[\"nome_alvo\"]\n    id = j[\"id_alvo\"]\n    emissores_raw = j[\"emissores_notificados\"]\n    responsaveis_raw = j[\"responsaveis\"]\n\n    emissores = ensure_list(\"emissores_notificados\", emissores_raw)\n    responsaveis = ensure_list(\"responsaveis\", responsaveis_raw)\n\n    # monta <ul> de emissores\n    li_parts = []\n    for em in emissores:\n        em = ensure_dict(\"emissor\", em)\n        emissor = escape(str(em[\"emissor\"]))\n        valor = float(em[\"valor\"])\n        li_parts.append(f\"<li>{emissor}, valor estimado de {to_brl(valor)}</li>\")\n    ul_html = \"<ul>\" + \"\".join(li_parts) + \"</ul>\"\n\n    descricao_html = (\n        f\"<p>O cliente <strong>{escape(str(nome))}</strong> possui aplicações sem cobertura do FGC nos seguintes emissores:</p>\"\n        f\"{ul_html}\"\n        f\"<p><em>Avalie a concentração e o risco da posição.</em></p>\"\n    )\n\n    # uma notificação por responsável\n    for resp in responsaveis:\n        # resp pode já ser int/str; se vier proxied, converte\n        if not isinstance(resp, (int, str)):\n            try:\n                resp = resp.to_py()\n            except Exception as e:\n                raise TypeError(f\"Responsável não é int/str nem JsProxy: {type(resp)}\") from e\n\n        novo = {\n            \"titulo\": \"Cliente com aplicações em emissores não cobertos pelo FGC\",\n            \"descricao\": descricao_html,  # HTML\n            \"destinatario\": resp,\n            \"cliente_pf_id\": id,\n            \"nome_cliente_pf\": nome,\n        }\n        new_items.append({\n            \"json\": novo,\n            \"pairedItem\": {\"item\": idx},  # preserva o vínculo com o item de entrada\n        })\n\nreturn new_items\n"
      },
      "type": "n8n-nodes-base.code",
