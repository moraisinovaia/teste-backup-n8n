      "parameters": {
        "functionCode": "const name = $json.projectName || $json.body?.projectName;\n\nif (!name) {\n  throw new Error(\"projectName is required\");\n}\n\nfunction slugify(text) {\n  return text\n    .normalize(\"NFD\")\n    .replace(/[\\u0300-\\u036f]/g, \"\")\n    .replace(/([a-z])([A-Z])/g, \"$1-$2\")\n    .toLowerCase()\n    .replace(/[^a-z0-9]+/g, \"-\")\n    .replace(/(^-|-$)/g, \"\");\n}\n\nconst slug = slugify(name);\n\nreturn [{\n  projectName: name,\n  slug,\n  backendRepo: `${slug}-backend`,\n  frontendRepo: `${slug}-frontend`,\n  backendDescription: `Backend Django API for ${name}`,\n  frontendDescription: `Frontend Vue app for ${name}`\n}];"
      },
