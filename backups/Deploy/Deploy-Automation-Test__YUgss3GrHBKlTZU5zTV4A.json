    {
      "parameters": {
        "functionCode": "// Pegamos o conteúdo e sha do node que buscou o .env.example\nconst file = $node[\"Get Front .env1\"].json;\n\n// Decodifica o conteúdo base64 para string\nconst content = Buffer.from(file.content, 'base64').toString('utf8');\n\n// Faz os replaces com os dados do workflow\nlet updated = content\n  .replace(/__PROJECT_NAME__/g, $json.projectName)\n  .replace(/__PROJECT_SLUG__/g, $json.slug);\n\n// Retorna o conteúdo atualizado em base64 + sha do arquivo original\nreturn [{\n  sha: file.sha,\n  updatedContent: Buffer.from(updated).toString('base64')\n}];"
      },
