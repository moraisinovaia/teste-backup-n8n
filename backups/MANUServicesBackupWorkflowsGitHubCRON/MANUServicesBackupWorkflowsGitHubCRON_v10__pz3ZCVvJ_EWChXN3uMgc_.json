    {
      "parameters": {
        "jsCode": "const workflow = $input.first().json;\nconst name = workflow.name || 'sem-nome';\n\nconst slugify = (text) => {\n  return text.toString()\n    .normalize('NFD').replace(/[\\u0300-\\u036f]/g, '')\n    .replace(/[^a-zA-Z0-9\\s-_]/g, '')\n    .replace(/\\s+/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '');\n};\n\n// Pega o primeiro segmento antes de _ - ou espaço\nconst firstSegment = name.split(/[_\\-\\s]/)[0];\nconst folder = slugify(firstSegment) || 'GERAL';\nconst cleanName = slugify(name);\n\n// Sanitizar credentials — remove IDs e nomes de credenciais\nconst sanitized = JSON.parse(JSON.stringify(workflow));\nif (sanitized.nodes) {\n  sanitized.nodes.forEach(node => {\n    if (node.credentials) {\n      for (const key of Object.keys(node.credentials)) {\n        node.credentials[key] = { id: '***', name: '***' };\n      }\n    }\n  });\n}\n\nconst filePath = `backups/${folder}/${cleanName}__${workflow.id}.json`;\nconst content = JSON.stringify(sanitized, null, 2);\n\nreturn [{\n  json: {\n    filePath,\n    content,\n    workflowName: workflow.name,\n    workflowId: workflow.id\n  }\n}];"
      },
