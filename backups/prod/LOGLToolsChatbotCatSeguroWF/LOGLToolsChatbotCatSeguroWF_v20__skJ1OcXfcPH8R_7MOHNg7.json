      "id": "bd28df6e-e29b-45e0-aaca-1895ba0e8f7e",
      "name": "chamadaChatbot"
    },
    {
      "parameters": {
        "jsCode": "const newItems = [];\n\nfor (const item of $input.all()) {\n  // --- EXTRAÇÃO DO INPUT ---\n  let input = item.json.input;\n\n  // Proteção: se o agente enviar input como string JSON\n  if (typeof input === 'string') {\n    try {\n      input = JSON.parse(input);\n    } catch (e) {\n      throw new Error('Formato inválido. O campo \"input\" não é um objeto JSON válido.');\n    }\n  }\n\n  let paths = input?.paths;\n\n  // Proteção: se paths vier como string JSON\n  if (typeof paths === 'string') {\n    try {\n      paths = JSON.parse(paths);\n    } catch (e) {\n      paths = [paths];\n    }\n  }\n\n  // 0. Validação de Esquema\n  if (!Array.isArray(paths)) {\n    throw new Error('Formato inválido. O campo \"paths\" deve ser um array de strings.');\n  }\n\n  for (let p of paths) {\n    if (typeof p !== 'string') {\n      throw new Error(`Acesso negado: Um dos caminhos fornecidos não é um texto válido.`);\n    }\n\n    if (!p.startsWith('/')) {\n      p = '/' + p;\n    }\n    p = p.replace(/\\/+/g, '/');\n\n    // 1. Bloqueia \"..\" (Path Traversal)\n    if (p.includes(\"..\")) {\n      throw new Error(`Acesso negado: Tentativa de Path Traversal (..) em ${p}`);\n    }\n\n    // 2. Bloqueia arquivos de ambiente\n    const envPattern = /(^|\\/)\\.?env(\\.|$|\\/)/i;\n    if (envPattern.test(p)) {\n      throw new Error(`Acesso negado: Tentativa de ler arquivo de configuração de ambiente restrito: ${p}`);\n    }\n\n    // 3. Validação rigorosa de caracteres\n    const safePattern = /^[a-zA-Z0-9/ \\-_\\.]+$/;\n    if (!safePattern.test(p)) {\n      throw new Error(`Acesso negado: O caminho contém caracteres perigosos ou não permitidos: ${p}`);\n    }\n\n    // 4. Validação de prefixos e arquivos\n    const allowedPrefixes = [\"/apps/\", \"/docs/\", \"/config/\"];\n    const allowedFiles = [\"/README.md\", \"/AGENTS.md\"];\n    const hasAllowedPrefix = allowedPrefixes.some(prefix => p.startsWith(prefix));\n    const isAllowedFile = allowedFiles.includes(p);\n\n    if (!hasAllowedPrefix && !isAllowedFile) {\n      throw new Error(`Acesso negado: O caminho '${p}' não está na lista de pastas ou arquivos permitidos.`);\n    }\n\n    // --- PREPARAÇÃO DO OUTPUT ---\n    const cleanJson = {};\n    cleanJson.safePath = p;\n\n    newItems.push({ json: cleanJson });\n  }\n}\n\nreturn newItems;"
      },
