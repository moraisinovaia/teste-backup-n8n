    {
      "parameters": {
        "jsCode": "// Limpa o nome do workflow para usar como nome de arquivo\nconst workflow = $input.first().json;\nconst name = workflow.name || 'sem-nome';\n\n// Remove caracteres especiais, substitui espaços por hífens\nconst cleanName = name\n  .toLowerCase()\n  .normalize('NFD')\n  .replace(/[\\u0300-\\u036f]/g, '') // remove acentos\n  .replace(/[^a-z0-9\\s-]/g, '')   // remove caracteres especiais\n  .replace(/\\s+/g, '-')            // espaços viram hífens\n  .replace(/-+/g, '-')             // remove hífens duplicados\n  .replace(/^-|-$/g, '');          // remove hífens no início/fim\n\nconst filePath = `backups/workflows/${cleanName}.json`;\n\n// Formata o JSON de forma legível\nconst content = JSON.stringify(workflow, null, 2);\n\nreturn [{\n  json: {\n    filePath,\n    content,\n    workflowName: workflow.name,\n    workflowId: workflow.id\n  }\n}];"
      },
