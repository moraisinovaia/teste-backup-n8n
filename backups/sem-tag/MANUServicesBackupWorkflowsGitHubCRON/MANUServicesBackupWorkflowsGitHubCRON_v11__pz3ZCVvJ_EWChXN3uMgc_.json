    {
      "parameters": {
        "jsCode": "const workflow = $input.first().json;\nconst name = workflow.name || 'sem-nome';\n\n// === SLUGIFY ===\nconst slugify = (text) => {\n  return text.toString()\n    .normalize('NFD').replace(/[\\u0300-\\u036f]/g, '')\n    .replace(/[^a-zA-Z0-9\\s-_]/g, '')\n    .replace(/\\s+/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '');\n};\n\n// === RESOLVER AMBIENTE VIA TAGS ===\n// Tags reconhecidas como ambiente (case-insensitive)\nconst ENV_TAGS = ['dev', 'prod'];\n\nconst workflowTags = (workflow.tags || [])\n  .map(t => (typeof t === 'string' ? t : t.name || '').toLowerCase().trim())\n  .filter(Boolean);\n\nconst envTag = workflowTags.find(t => ENV_TAGS.includes(t));\nconst environment = envTag || 'sem-tag';\n\n// === SUBPASTA POR PRIMEIRO SEGMENTO DO NOME ===\nconst firstSegment = name.split(/[_\\-\\s]/)[0];\nconst folder = slugify(firstSegment) || 'GERAL';\nconst cleanName = slugify(name);\n\n// === SANITIZAR CREDENTIALS ===\nconst sanitized = JSON.parse(JSON.stringify(workflow));\nif (sanitized.nodes) {\n  sanitized.nodes.forEach(node => {\n    if (node.credentials) {\n      for (const key of Object.keys(node.credentials)) {\n        node.credentials[key] = { id: '***', name: '***' };\n      }\n    }\n  });\n}\n\n// === MONTAR PATH: backups/{env}/{subpasta}/{arquivo} ===\nconst filePath = `backups/${environment}/${folder}/${cleanName}__${workflow.id}.json`;\nconst content = JSON.stringify(sanitized, null, 2);\n\nreturn [{\n  json: {\n    filePath,\n    content,\n    workflowName: workflow.name,\n    workflowId: workflow.id,\n    environment,\n    tags: workflowTags\n  }\n}];"
      },
